{
  "taskGroups": [
    {
      "taskSpec": {
          "runnables": [
            {
              "container": {
                "imageUri": "gcr.io/gatk-resources-490700/gatk-pipeline:latest",
                "commands": ["bash", "/workspace/variant-pipeline.sh"]
              }
            }
          ],
        "computeResource": {
          "cpuMilli": 8000,
          "memoryMib": 32000
        },
        "maxRetryCount": 1
      },
      "taskCount": 1
    }
  ],
  "allocationPolicy": {
    "instances": [
      {
        "policy": {
          "machineType": "n2-standard-8",
          "bootDisk": {
            "diskSizeGb": 200
          }
        }
      }
    ]
  },
  "logsPolicy": {
    "destination": "CLOUD_LOGGING"
  }
}