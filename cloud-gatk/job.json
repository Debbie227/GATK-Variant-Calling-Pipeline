{
  "taskGroups": [
    {
      "taskSpec": {
          "runnables": [
            {
              "container": {
                "image_uri": "gcr.io/gatk-resources-490700/gatk-pipeline:latest",
                "commands": ["bash", "/workspace/variant-pipeline.sh"]
              }
            }
          ],
        "compute_resource": {
          "cpu_milli": 8000,
          "memory_mib": 32000
        },
        "volumes": [
          {
            "gcs": {
              "remote_path": "gatk-resource-bucket"
            },
            "mount_path": "/mnt/share"
          }
        ],
        "max_retry_count": 2
      },
      "task_count": 1
    }
  ],
  "allocation_policy": {
    "instances": [
      {
        "policy": {
          "machine_type": "n2-standard-8",
          "provisioning_model": "SPOT"
        }
      }
    ],
    "location": {
      "zones": ["us-west1-a", "us-west1-b", "us-west1-c"]
    }
  },
  "logs_policy": {
    "destination": "CLOUD_LOGGING"
  }
}